{
  "name": "DMA-CP-ABE-V2X",
  "type": "CP-ABE",
  "variant": "decentralized-multi-authority",
  "security": "selective",
  "assumption": "SXDH",
  "curve": "BLS12-381",

  "predicate": {
    "x": {
      "description": "Access policy as LSSS matrix (A, rho)",
      "type": "lsss",
      "matrix": "A",
      "row_map": "rho",
      "row_map_range": "(att, authority)",
      "target_vector": "e_1"
    },
    "y": {
      "description": "Vehicle attribute set per authority, bound to GID",
      "type": "set",
      "structure": {
        "GID": "string",
        "S_theta": "map from authority index to attribute subset"
      }
    },
    "satisfaction": "exists I subset [n], {omega_j} s.t. sum_{j in I} omega_j * A_j = e_1"
  },

  "variables": {
    "master_secret": {
      "alpha": {
        "indexed_by": "theta",
        "range": "authorities",
        "group": "Zp"
      }
    },
    "common": {
      "b_att": {
        "indexed_by": "att",
        "range": "attribute_universe",
        "group": "G2"
      },
      "b_GID": {
        "type": "fdh",
        "input": "GID",
        "group": "G2"
      }
    },
    "key_randomness": {
      "r": {
        "indexed_by": "j",
        "range": "rows_of_A",
        "group": "Zp"
      }
    },
    "ciphertext_randomness": {
      "s": {
        "group": "Zp"
      },
      "lambda": {
        "indexed_by": "j",
        "range": "rows_of_A",
        "group": "Zp"
      }
    }
  },

  "encodings": {
    "key": {
      "indexed_by": ["j", "theta"],
      "index_constraint": "authority(rho(j)) == theta",
      "K1": {
        "expr": "\\alpha_{\\theta} + r_j \\cdot b_{att_j} + r_j \\cdot b_{GID}",
        "group": "G2"
      },
      "K2": {
        "expr": "r_j",
        "group": "G2"
      }
    },
    "ciphertext": {
      "C0": {
        "expr": "s",
        "group": "G1",
        "indexed": false
      },
      "C1": {
        "expr": "\\lambda_j + s \\cdot b_{att_j}",
        "group": "G1",
        "indexed_by": "j"
      },
      "C2": {
        "expr": "s",
        "group": "G1",
        "indexed_by": "j"
      },
      "C3": {
        "expr": "s \\cdot b_{GID}",
        "group": "G1",
        "indexed": false
      }
    }
  },

  "pairing": {
    "terms": [
      {
        "key_poly": "K1_j",
        "ct_poly":  "C2_j",
        "coeff":    "omega_j",
        "sign":     "+"
      },
      {
        "key_poly": "K2_j",
        "ct_poly":  "C1_j",
        "coeff":    "omega_j",
        "sign":     "-"
      },
      {
        "key_poly": "K2_j",
        "ct_poly":  "C3",
        "coeff":    "omega_j",
        "sign":     "-"
      }
    ],
    "result": "s \\cdot \\sum_{\\theta} \\alpha_{\\theta}",
    "target_group": "GT"
  }
}